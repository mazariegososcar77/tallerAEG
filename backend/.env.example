# Puerto del servidor HTTP
PORT=4000

# Origen permitido para CORS (frontend en desarrollo)
CORS_ORIGIN=http://localhost:5173

# Secreto para firmar los JWT. Cambialo en produccion por un valor largo y aleatorio.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Tiempo de expiracion del token (formato de la libreria jsonwebtoken: 1h, 8h, 7d, etc.)
JWT_EXPIRES=8h
